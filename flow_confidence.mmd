flowchart LR
    OB["Order Block\nDetectado"] --> CALC["CALCULAR ÍNDICE\nDE CONFIANÇA\n(0-100 pontos)"]
    
    CALC --> V["Volume Score\n0-25 pts\n(Volume vs MA 20)"]
